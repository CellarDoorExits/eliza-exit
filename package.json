{
  "name": "@cellar-door/eliza",
  "version": "0.1.0",
  "type": "module",
  "description": "EXIT Protocol plugin for ElizaOS — departure records for AI agents",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "cellar-door-exit": "^0.2.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0 <2.0.0"
  },
  "devDependencies": {
    "@elizaos/core": "^0.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/CellarDoorExits/eliza-exit.git"
  },
  "homepage": "https://github.com/CellarDoorExits/eliza-exit",
  "keywords": [
    "exit",
    "eliza",
    "elizaos",
    "ai-agent",
    "departure",
    "plugin",
    "web3"
  ]
}
